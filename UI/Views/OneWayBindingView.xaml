<UserControl x:Class="UI.Views.OneWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Односторонние привязки"
                       Style="{StaticResource SectionHeader}" />
            <TextBlock Style="{StaticResource InfoLabel}"
                       Text="OneWay: данные идут только от Source → Target. OneWayToSource: только от Target → Source." />

            <!-- OneWay через ViewModel -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🔗 OneWay (Source → Target) через ViewModel"
                               Style="{StaticResource SubHeader}" />
                    <TextBlock Style="{StaticResource InfoLabel}"
                               Text="Таймер обновляет ViewModel, UI отображает. Пользователь НЕ может изменить значение обратно." />

                    <TextBlock Margin="0,4">
                        <Run Text="Текущее время: " />
                        <Run Text="{Binding CurrentTime, Mode=OneWay}"
                             FontSize="18"
                             FontWeight="Bold"
                             Foreground="{StaticResource PrimaryBrush}" />
                    </TextBlock>

                    <TextBlock Margin="0,4">
                        <Run Text="Тиков: " />
                        <Run Text="{Binding TickCount, Mode=OneWay}"
                             FontWeight="Bold" />
                    </TextBlock>

                    <TextBlock Text="Прогресс (OneWay):"
                               Margin="0,8,0,2" />
                    <ProgressBar Height="20"
                                 Maximum="100"
                                 Value="{Binding Progress, Mode=OneWay}" />

                    <Button Content="Старт/Стоп таймера"
                            Command="{Binding ToggleTimerCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- OneWayToSource через ViewModel -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🔗 OneWayToSource (Target → Source) через ViewModel"
                               Style="{StaticResource SubHeader}" />
                    <TextBlock Style="{StaticResource InfoLabel}"
                               Text="Пользовательский ввод попадает в ViewModel, но ViewModel не может обновить TextBox." />

                    <TextBlock Text="TextBox (OneWayToSource):"
                               Margin="0,4,0,0" />
                    <TextBox Text="{Binding UserInput, Mode=OneWayToSource, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Margin="0,4">
                        <Run Text="В ViewModel получено: " />
                        <Run Text="{Binding UserInput, Mode=OneWay}"
                             FontWeight="Bold"
                             Foreground="{StaticResource PrimaryBrush}" />
                    </TextBlock>

                    <Button Content="Попытаться установить из ViewModel"
                            Command="{Binding UpdateFromVmCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0" />
                    <TextBlock Style="{StaticResource InfoLabel}"
                               Text="⬆️ Кнопка меняет значение в ViewModel, но TextBox (OneWayToSource) НЕ обновится." />
                </StackPanel>
            </Border>

            <!-- Прямая привязка ElementName -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🔗 Прямая привязка (ElementName)"
                               Style="{StaticResource SubHeader}" />

                    <TextBlock Text="OneWay: Slider → ProgressBar"
                               Margin="0,4,0,0" />
                    <Slider x:Name="OwSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="30" />
                    <ProgressBar Height="18"
                                 Maximum="100"
                                 Value="{Binding Value, ElementName=OwSlider, Mode=OneWay}"
                                 Margin="0,4" />

                    <TextBlock Text="OneWay: TextBox → TextBlock"
                               Margin="0,12,0,0" />
                    <TextBox x:Name="OwSource"
                             Text="Только чтение для приёмника" />
                    <TextBlock Text="{Binding Text, ElementName=OwSource, Mode=OneWay}"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,4" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
