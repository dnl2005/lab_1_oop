<UserControl x:Class="UI.Views.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Привязка по умолчанию (Default Binding)"
                       Style="{StaticResource SectionHeader}" />
            <TextBlock Style="{StaticResource InfoLabel}"
                       Text="Режим привязки зависит от контрола: для TextBox по умолчанию — TwoWay, для TextBlock — OneWay. Ниже показана разница между привязкой напрямую к элементу (ElementName) и через ViewModel." />

            <!-- Секция 1: Привязка через ViewModel -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🔗 Привязка через ViewModel"
                               Style="{StaticResource SubHeader}" />

                    <TextBlock Text="TextBox (Default = TwoWay для TextBox):"
                               Margin="0,4,0,0" />
                    <TextBox Text="{Binding TextValue}" />

                    <TextBlock Text="Значение из ViewModel (TextBlock, Default = OneWay):"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding TextValue}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,4" />

                    <TextBlock Text="Slider (Default = TwoWay для Slider):"
                               Margin="0,8,0,0" />
                    <Slider Minimum="0"
                            Maximum="100"
                            Value="{Binding SliderValue}" />
                    <TextBlock Margin="0,2">
                        <Run Text="Значение слайдера: " />
                        <Run Text="{Binding SliderValue, Mode=OneWay}"
                             FontWeight="Bold" />
                    </TextBlock>

                    <CheckBox Content="CheckBox (Default = TwoWay)"
                              IsChecked="{Binding IsChecked}"
                              Margin="0,8,0,0" />
                    <TextBlock Margin="0,2">
                        <Run Text="IsChecked: " />
                        <Run Text="{Binding IsChecked, Mode=OneWay}"
                             FontWeight="Bold" />
                    </TextBlock>

                    <Button Content="Сбросить значения из ViewModel"
                            Command="{Binding ResetCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- Секция 2: Привязка напрямую к элементу (ElementName) -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="🔗 Прямая привязка к элементу (ElementName)"
                               Style="{StaticResource SubHeader}" />
                    <TextBlock Style="{StaticResource InfoLabel}"
                               Text="Здесь привязка идёт не через ViewModel, а напрямую между контролами." />

                    <TextBlock Text="Источник (TextBox):"
                               Margin="0,4,0,0" />
                    <TextBox x:Name="SourceTextBox"
                             Text="Напишите что-нибудь" />

                    <TextBlock Text="Приёмник (TextBlock, ElementName):"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding Text, ElementName=SourceTextBox}"
                               FontSize="14"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Bold" />

                    <TextBlock Text="Источник (Slider):"
                               Margin="0,12,0,0" />
                    <Slider x:Name="SourceSlider"
                            Minimum="0"
                            Maximum="100"
                            Value="50" />
                    <ProgressBar Height="20"
                                 Value="{Binding Value, ElementName=SourceSlider}"
                                 Maximum="100"
                                 Margin="0,4" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
